# Copy to .env (or set these in your shell) to enable optional integrations.
# The tool runs without any of these — they unlock extra sources / LLM scoring.

# Enables open-weight AI match scoring through OpenRouter (default model:
# z-ai/glm-5.2). Without it, the app falls back to Claude if configured, then
# weighted keyword overlap.
OPENROUTER_API_KEY=

# Optional Claude fallback match scoring (Section 7).
ANTHROPIC_API_KEY=

# Enables the SerpAPI Google Jobs source (Tier 3, breadth). Without it, that
# source is skipped with a logged note.
SERPAPI_API_KEY=

# Optional: a GitHub token raises the API rate limit when checking curated-repo
# freshness and pulling READMEs. Public access works without it, just slower.
GITHUB_TOKEN=
